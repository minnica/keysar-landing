---
const videos = [
  {
    id: 1,
    webm: "/videos/video-01.webm",
    mp4: "/videos/video-01-optimizado.mp4",
    poster: "/videos/video-01-poster.webp",
  },
  {
    id: 2,
    webm: "/videos/video-02.webm",
    mp4: "/videos/video-02-optimizado.mp4",
    poster: "/videos/video-02-poster.webp",
  },
  {
    id: 3,
    webm: "/videos/video-03.webm",
    mp4: "/videos/video-03-optimizado.mp4",
    poster: "/videos/video-03-poster.webp",
  },
  {
    id: 4,
    webm: "/videos/video-04.webm",
    mp4: "/videos/video-04-optimizado.mp4",
    poster: "/videos/video-04-poster.webp",
  },
  {
    id: 5,
    webm: "/videos/video-05.webm",
    mp4: "/videos/video-05-optimizado.mp4",
    poster: "/videos/video-05-poster.webp",
  },
  {
    id: 6,
    webm: "/videos/video-06.webm",
    mp4: "/videos/video-06-optimizado.mp4",
    poster: "/videos/video-06-poster.webp",
  },
  {
    id: 7,
    webm: "/videos/video-07.webm",
    mp4: "/videos/video-07-optimizado.mp4",
    poster: "/videos/video-07-poster.webp",
  },
  {
    id: 8,
    webm: "/videos/video-08.webm",
    mp4: "/videos/video-08-optimizado.mp4",
    poster: "/videos/video-08-poster.webp",
  },
  {
    id: 9,
    webm: "/videos/video-09.webm",
    mp4: "/videos/video-09-optimizado.mp4",
    poster: "/videos/video-09-poster.webp",
  },
  {
    id: 10,
    webm: "/videos/video-10.webm",
    mp4: "/videos/video-10-optimizado.mp4",
    poster: "/videos/video-10-poster.webp",
  },
  {
    id: 11,
    webm: "/videos/video-11.webm",
    mp4: "/videos/video-11-optimizado.mp4",
    poster: "/videos/video-11-poster.webp",
  },
