<header class="absolute left-0 top-0 z-30 w-full">
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 md:px-10"
  >
    <a href="/" aria-label="Keysar Cosmetics" class="inline-flex items-center">
      <img
        src="/images/logo-keysar.svg"
        alt="Keysar Cosmetics"
        class="h-8 w-auto md:h-9"
      />
    </a>

    <div
      class="hidden items-center gap-8 text-sm font-medium text-keysar-text md:flex"
    >
      <a href="#conocenos" class="transition hover:text-keysar-gold">
        Conócenos
      </a>

      <a href="#servicios" class="transition hover:text-keysar-gold">
        Servicios
      </a>

      <a href="#agenda" class="transition hover:text-keysar-gold">
        Agendar cita
      </a>

      <a
        href="#agenda"
        aria-label="Ir a agendar cita"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-keysar-text/30 text-keysar-text transition hover:border-keysar-gold hover:text-keysar-gold"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 21a8 8 0 0 0-16 0"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </a>
    </div>

    <details class="group relative md:hidden">
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full border border-keysar-text/30 text-keysar-text"
        aria-label="Abrir menú"
      >
        <span class="sr-only">Abrir menú</span>

        <svg
          class="h-5 w-5 group-open:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M4 7h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 17h16"></path>
        </svg>

        <svg
          class="hidden h-5 w-5 group-open:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12"></path>
          <path d="M18 6L6 18"></path>
        </svg>
      </summary>

      <div
        class="absolute right-0 top-12 w-56 rounded-2xl border border-keysar-text/10 bg-white/95 p-3 text-sm font-medium text-keysar-text shadow-lg backdrop-blur"
      >
        <a
          href="#conocenos"
          class="block rounded-xl px-4 py-3 transition hover:bg-keysar-cream"
        >
          Conócenos
        </a>

        <a
          href="#servicios"
          class="block rounded-xl px-4 py-3 transition hover:bg-keysar-cream"
        >
          Servicios
        </a>

        <a
          href="#agenda"
          class="block rounded-xl px-4 py-3 transition hover:bg-keysar-cream"
        >
          Agendar cita
        </a>
      </div>
    </details>
  </nav>
</header>
