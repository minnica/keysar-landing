---
import { whatsappPhoneNumber } from "../constants/contact";
---

<section
  id="agenda"
  class="bg-keysar-cream px-5 py-16 sm:px-6 md:px-10 md:py-20 lg:py-24"
>
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-[420px]">
      <div
        class="w-full border border-keysar-gold/40 bg-[#f8eee9] p-5 shadow-sm sm:p-7"
      >
        <h3 class="text-base font-semibold text-keysar-dark">
          Agenda tu experiencia
        </h3>

        <p class="mt-4 text-sm leading-6 text-keysar-text">
          Déjanos tus datos y una asesora se pondrá en contacto contigo para
          personalizar tu cita.
        </p>

        <form
          class="mt-6 space-y-4"
          data-appointment-form
          data-whatsapp-phone={whatsappPhoneNumber}
        >
          <div>
            <label for="name" class="sr-only">Nombre(s)</label>
            <input
              id="name"
              name="name"
              type="text"
              placeholder="Nombre(s)"
              class="w-full border border-keysar-text/35 bg-transparent px-4 py-3 text-sm text-keysar-text outline-none placeholder:text-keysar-gray focus:border-keysar-gold"
            />
          </div>

          <div class="relative">
            <label for="service" class="sr-only">Servicio de interés</label>
            <select
              id="service"
              name="service"
              class="w-full appearance-none border border-keysar-text/35 bg-transparent px-4 py-3 pr-12 text-sm text-keysar-text outline-none focus:border-keysar-gold"
            >
              <option value="">Servicio de interés</option>
              <option value="facial">Facial</option>
              <option value="corporal">Corporal</option>
            </select>

            <svg
              class="pointer-events-none absolute right-4 top-1/2 h-4 w-4 -translate-y-1/2 text-keysar-text"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </div>

          <div class="relative">
            <label for="branch" class="sr-only">Sucursal</label>
            <select
              id="branch"
              name="branch"
              class="w-full appearance-none border border-keysar-text/35 bg-transparent px-4 py-3 pr-12 text-sm text-keysar-text outline-none focus:border-keysar-gold"
            >
              <option value="">Sucursal</option>
              <option value="sucursal-1">Sucursal Masaryk</option>
              <option value="sucursal-2">Keysar Cosmétics Mítikah Luxury</option>
              <option value="sucursal-2">Sucursal Parque Delta Beauty Córner</option>
            </select>

            <svg
              class="pointer-events-none absolute right-4 top-1/2 h-4 w-4 -translate-y-1/2 text-keysar-text"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </div>

          <div class="grid grid-cols-1 gap-3 sm:grid-cols-[72px_1fr]">
            <div
              class="flex items-center border border-keysar-text/35 bg-transparent px-3 py-3 text-sm text-keysar-text"
            >
              🇲🇽 +52
            </div>

            <div>
              <label for="phone" class="sr-only">Teléfono</label>
              <input
                id="phone"
                name="phone"
                type="tel"
                placeholder="Escribe tu número sin espacios"
                class="w-full border border-keysar-text/35 bg-transparent px-4 py-3 text-sm text-keysar-text outline-none placeholder:text-keysar-gray focus:border-keysar-gold"
              />
            </div>
          </div>

          <label class="flex gap-3 text-xs leading-5 text-keysar-gray">
            <input
              type="checkbox"
              name="privacy"
              class="mt-1 h-4 w-4 shrink-0 accent-keysar-gold"
            />

            <span>
              Acepto el envío de información a mi correo electrónico. He leído y
              revisado la Política de Protección de Datos.
            </span>
          </label>

          <button
            type="submit"
            class="w-full rounded-full bg-keysar-gold px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#ad8f6d]"
          >
            Agendar cita
          </button>

          <a
            href={`https://wa.me/${whatsappPhoneNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            data-whatsapp-appointment
            class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-keysar-gold/45 bg-transparent px-6 py-3 text-sm font-semibold text-keysar-text transition hover:border-keysar-gold hover:bg-white/50 focus:outline-none focus:ring-4 focus:ring-keysar-gold/20"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 3a8.8 8.8 0 0 0-7.6 13.2L3.4 21l4.9-1.3A8.8 8.8 0 1 0 12 3Zm0 15.9c-1.3 0-2.6-.4-3.7-1l-.3-.2-2.1.6.6-2-.2-.3A7.1 7.1 0 1 1 12 18.9Zm4-5.3c-.2-.1-1.3-.7-1.5-.7s-.4-.1-.6.1c-.2.2-.7.7-.8.8-.1.2-.3.2-.5.1-.2-.1-1-.4-1.9-1.2-.7-.6-1.2-1.4-1.3-1.6-.1-.2 0-.4.1-.5l.4-.4c.1-.1.2-.3.3-.4.1-.2 0-.3 0-.5 0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.2-.9.9-.9 2.1s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.5.6.2 1.2.2 1.6.1.5-.1 1.3-.5 1.5-1 .2-.5.2-.9.1-1 0-.1-.2-.2-.4-.3Z"
              ></path>
            </svg>
            Continuar por WhatsApp
          </a>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const appointmentForm = document.querySelector("[data-appointment-form]");
  const whatsappAppointmentLink = document.querySelector(
    "[data-whatsapp-appointment]",
  );

  function getInputValue(form, fieldName) {
    const formData = new FormData(form);
    return formData.get(fieldName)?.toString().trim() ?? "";
  }

  function getSelectedText(form, fieldName) {
    const field = form.elements.namedItem(fieldName);

    if (!(field instanceof HTMLSelectElement)) {
      return "";
    }

    const selectedOption = field.selectedOptions[0];
    const selectedValue = selectedOption?.value ?? "";

    return selectedValue ? selectedOption.textContent?.trim() ?? "" : "";
  }

  function buildAppointmentMessage(form) {
    const name = getInputValue(form, "name");
    const phone = getInputValue(form, "phone");
    const service = getSelectedText(form, "service");
    const branch = getSelectedText(form, "branch");

    return [
      "Hola, quiero agendar una cita en Keysar Cosmetics.",
      name ? `Mi nombre es ${name}.` : "",
      service ? `Servicio de interés: ${service}.` : "",
      branch ? `Sucursal: ${branch}.` : "",
      phone ? `Mi teléfono es +52 ${phone}.` : "",
      "Quedo al pendiente de su confirmación.",
    ]
      .filter(Boolean)
      .join(" ");
  }

  function updateWhatsAppAppointmentUrl() {
    if (!appointmentForm || !whatsappAppointmentLink) {
      return "";
    }

    const phoneNumber = appointmentForm.dataset.whatsappPhone;
    const message = encodeURIComponent(buildAppointmentMessage(appointmentForm));
    const url = `https://wa.me/${phoneNumber}?text=${message}`;

    whatsappAppointmentLink.setAttribute("href", url);

    return url;
  }

  if (appointmentForm) {
    appointmentForm.addEventListener("input", updateWhatsAppAppointmentUrl);
    appointmentForm.addEventListener("change", updateWhatsAppAppointmentUrl);
    appointmentForm.addEventListener("submit", (event) => {
      event.preventDefault();

      const whatsappUrl = updateWhatsAppAppointmentUrl();

      if (whatsappUrl) {
        window.open(whatsappUrl, "_blank", "noopener,noreferrer");
      }
    });

    updateWhatsAppAppointmentUrl();
  }
</script>
