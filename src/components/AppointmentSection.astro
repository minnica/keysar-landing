---
import { whatsappPhoneNumber } from "../constants/contact";
---

<section
  id="agenda"
  class="ks-section-d px-5 py-20 sm:px-6 md:px-10 lg:py-28"
>
  <div class="mx-auto max-w-7xl">
    <div class="grid items-center gap-14 lg:grid-cols-2 xl:gap-24">

      <!-- Editorial anchor -->
      <div class="lg:max-w-lg">
        <p
          class="text-xs font-semibold uppercase tracking-[0.18em] text-keysar-gold"
        >
          Reserva tu momento
        </p>

        <h2
          class="mt-4 font-title text-4xl leading-tight tracking-[-0.02em] text-keysar-dark sm:text-5xl"
        >
          Agenda tu<br class="hidden sm:block" /> experiencia
        </h2>

        <div class="mt-6 h-px w-14 bg-keysar-gold/60" aria-hidden="true"></div>

        <p class="mt-6 text-base leading-8 text-keysar-text">
          Una asesora especializada se pondrá en contacto contigo para
          personalizar cada detalle de tu visita y elegir el tratamiento ideal
          para ti.
        </p>

        <ul class="mt-8 space-y-3" aria-label="Beneficios del servicio">
          {
            [
              "Atención personalizada desde el primer contacto",
              "Horarios flexibles adaptados a tu agenda",
              "Experiencia premium en cada visita",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm leading-6 text-keysar-text">
                <span
                  class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-keysar-gold"
                  aria-hidden="true"
                />
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Form card -->
      <div>
        <div
          class="border border-keysar-gold/30 bg-[#faf7f4] px-7 py-8 shadow-sm sm:px-9 sm:py-10"
        >
          <p
            class="text-xs font-semibold uppercase tracking-[0.16em] text-keysar-gold"
          >
            Tu cita
          </p>
          <h3 class="mt-1 text-lg font-semibold text-keysar-dark">
            Completa tus datos
          </h3>

          <form
            class="mt-6 space-y-4"
            data-appointment-form
            data-whatsapp-phone={whatsappPhoneNumber}
          >
            <div>
              <label for="name" class="sr-only">Nombre(s)</label>
              <input
                id="name"
                name="name"
                type="text"
                placeholder="Nombre(s)"
                class="w-full border border-keysar-text/30 bg-transparent px-4 py-3 text-sm text-keysar-text outline-none placeholder:text-keysar-gray transition duration-200 focus:border-keysar-gold"
              />
            </div>

            <div class="relative">
              <label for="service" class="sr-only">Servicio de interés</label>
              <select
                id="service"
                name="service"
                class="w-full appearance-none border border-keysar-text/30 bg-transparent px-4 py-3 pr-12 text-sm text-keysar-text outline-none transition duration-200 focus:border-keysar-gold"
              >
                <option value="">Servicio de interés</option>
                <option value="facial">Facial</option>
                <option value="corporal">Corporal</option>
              </select>

              <svg
                class="pointer-events-none absolute right-4 top-1/2 h-4 w-4 -translate-y-1/2 text-keysar-text"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </div>

            <div class="relative">
              <label for="branch" class="sr-only">Sucursal</label>
              <select
                id="branch"
                name="branch"
                class="w-full appearance-none border border-keysar-text/30 bg-transparent px-4 py-3 pr-12 text-sm text-keysar-text outline-none transition duration-200 focus:border-keysar-gold"
              >
                <option value="">Sucursal</option>
                <option value="sucursal-1">Sucursal Masaryk</option>
                <option value="sucursal-2"
                  >Keysar Cosmétics Mítikah Luxury</option
                >
                <option value="sucursal-3"
                  >Sucursal Parque Delta Beauty Córner</option
                >
              </select>

              <svg
                class="pointer-events-none absolute right-4 top-1/2 h-4 w-4 -translate-y-1/2 text-keysar-text"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </div>

            <div>
              <label for="phone" class="sr-only">Teléfono</label>
              <input
                id="phone"
                name="phone"
                type="tel"
                placeholder="Teléfono"
                class="w-full border border-keysar-text/30 bg-transparent px-4 py-3 text-sm text-keysar-text outline-none placeholder:text-keysar-gray transition duration-200 focus:border-keysar-gold"
              />
            </div>

            <button
              type="submit"
              class="w-full rounded-full bg-keysar-gold px-6 py-3.5 text-sm font-semibold text-white transition duration-200 hover:bg-[#ad8f6d] focus:outline-none focus:ring-4 focus:ring-keysar-gold/30"
            >
              Agendar cita
            </button>

            <a
              href={`https://wa.me/${whatsappPhoneNumber}`}
              target="_blank"
              rel="noopener noreferrer"
              data-whatsapp-appointment
              class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-keysar-gold/45 bg-transparent px-6 py-3.5 text-sm font-semibold text-keysar-text transition duration-200 hover:border-keysar-gold hover:bg-white/60 focus:outline-none focus:ring-4 focus:ring-keysar-gold/20"
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 3a8.8 8.8 0 0 0-7.6 13.2L3.4 21l4.9-1.3A8.8 8.8 0 1 0 12 3Zm0 15.9c-1.3 0-2.6-.4-3.7-1l-.3-.2-2.1.6.6-2-.2-.3A7.1 7.1 0 1 1 12 18.9Zm4-5.3c-.2-.1-1.3-.7-1.5-.7s-.4-.1-.6.1c-.2.2-.7.7-.8.8-.1.2-.3.2-.5.1-.2-.1-1-.4-1.9-1.2-.7-.6-1.2-1.4-1.3-1.6-.1-.2 0-.4.1-.5l.4-.4c.1-.1.2-.3.3-.4.1-.2 0-.3 0-.5 0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.2-.9.9-.9 2.1s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.5.6.2 1.2.2 1.6.1.5-.1 1.3-.5 1.5-1 .2-.5.2-.9.1-1 0-.1-.2-.2-.4-.3Z"
                ></path>
              </svg>
              Continuar por WhatsApp
            </a>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const appointmentForm = document.querySelector("[data-appointment-form]");
  const whatsappAppointmentLink = document.querySelector(
    "[data-whatsapp-appointment]",
  );

  function getInputValue(form, fieldName) {
    const formData = new FormData(form);
    return formData.get(fieldName)?.toString().trim() ?? "";
  }

  function getSelectedText(form, fieldName) {
    const field = form.elements.namedItem(fieldName);

    if (!(field instanceof HTMLSelectElement)) {
      return "";
    }

    const selectedOption = field.selectedOptions[0];
    const selectedValue = selectedOption?.value ?? "";

    return selectedValue ? selectedOption.textContent?.trim() ?? "" : "";
  }

  function buildAppointmentMessage(form) {
    const name = getInputValue(form, "name");
    const phone = getInputValue(form, "phone");
    const service = getSelectedText(form, "service");
    const branch = getSelectedText(form, "branch");

    return [
      "Hola, quiero agendar una cita en Keysar Cosmetics.",
      name ? `Mi nombre es ${name}.` : "",
      service ? `Servicio de interés: ${service}.` : "",
      branch ? `Sucursal: ${branch}.` : "",
      phone ? `Mi teléfono es +52 ${phone}.` : "",
      "Quedo al pendiente de su confirmación.",
    ]
      .filter(Boolean)
      .join(" ");
  }

  function updateWhatsAppAppointmentUrl() {
    if (!appointmentForm || !whatsappAppointmentLink) {
      return "";
    }

    const phoneNumber = appointmentForm.dataset.whatsappPhone;
    const message = encodeURIComponent(buildAppointmentMessage(appointmentForm));
    const url = `https://wa.me/${phoneNumber}?text=${message}`;

    whatsappAppointmentLink.setAttribute("href", url);

    return url;
  }

  if (appointmentForm) {
    appointmentForm.addEventListener("input", updateWhatsAppAppointmentUrl);
    appointmentForm.addEventListener("change", updateWhatsAppAppointmentUrl);
    appointmentForm.addEventListener("submit", (event) => {
      event.preventDefault();

      const whatsappUrl = updateWhatsAppAppointmentUrl();

      if (whatsappUrl) {
        window.open(whatsappUrl, "_blank", "noopener,noreferrer");
      }
    });

    updateWhatsAppAppointmentUrl();
  }
</script>
