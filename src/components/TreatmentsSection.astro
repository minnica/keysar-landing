    description: "Reafirma, redefine y mejora la elasticidad facial.",
  },
  {
    title: "Anti Acné",
    description: "Equilibrio profundo para pieles con tendencia acneica.",
  },
  {
    title: "Cryoskin",
    description: "Efecto tensor y revitalizante con tecnología de frío.",
  },
  {
    title: "Eternal Eye",
    description: "Rejuvenece e ilumina la zona del contorno de ojos.",
  },
  {
