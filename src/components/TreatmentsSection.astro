---

<section id="servicios" class="ks-section-b px-6 py-20 md:px-10 lg:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <h2
        class="font-title text-3xl leading-tight tracking-normal text-keysar-text sm:text-4xl md:text-5xl"
      >
        Rituales creados para ti
      </h2>

      <div class="mt-5 flex items-center justify-center gap-3">
        {
          treatmentGroups.map((group, index) => (
            <button
              type="button"
              data-treatment-tab={group.key}
              aria-pressed={index === 0 ? "true" : "false"}
              class={`rounded-full px-5 py-1.5 text-xs font-semibold transition ${
                index === 0
                  ? "bg-keysar-gold text-white"
                  : "bg-[#efe4dc] text-keysar-text"
              }`}
            >
              {group.label}
            </button>
          ))
        }
      </div>
    </div>

    {
      treatmentGroups.map((group, groupIndex) => (
        <div
          data-treatment-panel={group.key}
          class={groupIndex === 0 ? "" : "hidden"}
        >
          <div class="mt-10 lg:mt-12">
            <div class="flex items-center justify-end gap-2">
              <button
                type="button"
                data-carousel-prev={group.key}
                aria-label={`Ver tratamiento anterior de ${group.label.toLowerCase()}`}
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-keysar-gold/40 bg-white text-keysar-text shadow-sm transition hover:border-keysar-gold hover:text-keysar-gold disabled:cursor-not-allowed disabled:opacity-35"
              >
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m15 18-6-6 6-6"></path>
                </svg>
              </button>

              <button
                type="button"
                data-carousel-next={group.key}
                aria-label={`Ver siguiente tratamiento de ${group.label.toLowerCase()}`}
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-keysar-gold/40 bg-white text-keysar-text shadow-sm transition hover:border-keysar-gold hover:text-keysar-gold disabled:cursor-not-allowed disabled:opacity-35"
              >
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </button>
            </div>

            <div
              data-treatment-carousel={group.key}
              role="region"
              aria-label={`Carrusel de ${group.ariaLabel}`}
              tabindex="0"
              class="mt-4 grid auto-cols-[100%] grid-flow-col snap-x snap-mandatory items-stretch gap-6 overflow-x-auto scroll-smooth pb-4 [scrollbar-width:none] sm:auto-cols-[calc((100%_-_1.75rem)/2)] sm:gap-7 lg:auto-cols-[calc((100%_-_4rem)/3)] lg:gap-8 [&::-webkit-scrollbar]:hidden"
            >
              {group.treatments.map((treatment) => (
                <article class="group flex snap-start flex-col overflow-hidden rounded-[4px] bg-[#f7eee9] shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
                  <div class="aspect-[1.75/1] overflow-hidden">
                    <img
                      src={treatment.imageSrc}
                      alt={treatment.imageAlt}
                      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>

                  <div class="flex flex-1 flex-col px-8 py-7 text-center">
                    <h3 class="mx-auto flex min-h-[58px] max-w-[290px] items-center justify-center font-title text-xl leading-tight text-keysar-text">
                      {treatment.title}
                    </h3>

                    <div class="mx-auto mt-4 h-px w-full max-w-[220px] bg-keysar-gold/60" />

                    <p class="mx-auto mt-5 min-h-[72px] max-w-[280px] text-sm leading-6 text-keysar-gray">
                      {treatment.description}
                    </p>

                    <a
                      href="#agenda"
                      class="mt-auto inline-flex justify-center pt-6 text-sm font-medium text-keysar-gold transition hover:text-keysar-text"
                    >
                      Descubrir tratamiento →
                    </a>
                  </div>
                </article>
              ))}
            </div>

            <div
              class="mt-2 flex items-center justify-center gap-2"
              aria-hidden="true"
            >
              {group.treatments.map((_, index) => (
                <span
                  data-carousel-dot={group.key}
                  class={`h-2 rounded-full transition-all ${
                    index === 0
                      ? "w-6 bg-keysar-gold"
                      : "w-2 bg-keysar-gold/30"
                  }`}
                />
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  const tabButtons = document.querySelectorAll("[data-treatment-tab]");
  const panels = document.querySelectorAll("[data-treatment-panel]");
  const carousels = document.querySelectorAll("[data-treatment-carousel]");
  const previousButtons = document.querySelectorAll("[data-carousel-prev]");
  const nextButtons = document.querySelectorAll("[data-carousel-next]");

  function getCarouselStep(carousel) {
    const card = carousel.querySelector("article");

    if (!card) {
      return carousel.clientWidth;
    }

    const styles = window.getComputedStyle(carousel);
    const gap = Number.parseFloat(styles.columnGap || styles.gap || "0");

    return card.getBoundingClientRect().width + gap;
  }

  function updateCarouselState(carousel) {
    const carouselKey = carousel.dataset.treatmentCarousel;

    if (!carouselKey) {
      return;
    }

    const dots = document.querySelectorAll(
      `[data-carousel-dot="${carouselKey}"]`,
    );
    const currentIndex = Math.max(
      0,
      Math.round(carousel.scrollLeft / getCarouselStep(carousel)),
    );
    const previousButton = document.querySelector(
      `[data-carousel-prev="${carouselKey}"]`,
    );
    const nextButton = document.querySelector(
      `[data-carousel-next="${carouselKey}"]`,
    );
    const atStart = carousel.scrollLeft <= 2;
    const atEnd =
      carousel.scrollLeft >= carousel.scrollWidth - carousel.clientWidth - 2;

    dots.forEach((dot, index) => {
      const isActive = index === currentIndex;

      dot.classList.toggle("w-6", isActive);
      dot.classList.toggle("bg-keysar-gold", isActive);
      dot.classList.toggle("w-2", !isActive);
      dot.classList.toggle("bg-keysar-gold/30", !isActive);
    });

    if (previousButton instanceof HTMLButtonElement) {
      previousButton.disabled = atStart;
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.disabled = atEnd;
    }
  }

  function moveCarousel(carouselKey, direction) {
    const carousel = document.querySelector(
      `[data-treatment-carousel="${carouselKey}"]`,
    );

    if (!carousel) {
      return;
    }

    carousel.scrollBy({
      left: getCarouselStep(carousel) * direction,
      behavior: "smooth",
    });
  }

  function setActiveTab(selectedTab) {
    tabButtons.forEach((button) => {
      const isActive = button.dataset.treatmentTab === selectedTab;

      button.classList.toggle("bg-keysar-gold", isActive);
      button.classList.toggle("text-white", isActive);

      button.classList.toggle("bg-[#efe4dc]", !isActive);
      button.classList.toggle("text-keysar-text", !isActive);

      button.setAttribute("aria-pressed", String(isActive));
    });

    panels.forEach((panel) => {
      const isActive = panel.dataset.treatmentPanel === selectedTab;
      panel.classList.toggle("hidden", !isActive);
    });

    const activeCarousel = document.querySelector(
      `[data-treatment-carousel="${selectedTab}"]`,
    );

    if (activeCarousel) {
      window.requestAnimationFrame(() => updateCarouselState(activeCarousel));
    }
  }

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setActiveTab(button.dataset.treatmentTab);
    });
  });

  previousButtons.forEach((button) => {
    button.addEventListener("click", () => {
      moveCarousel(button.dataset.carouselPrev, -1);
    });
  });

  nextButtons.forEach((button) => {
    button.addEventListener("click", () => {
      moveCarousel(button.dataset.carouselNext, 1);
    });
  });

  carousels.forEach((carousel) => {
    let waitingForFrame = false;

    carousel.addEventListener("scroll", () => {
      if (waitingForFrame) {
        return;
      }

      waitingForFrame = true;
      window.requestAnimationFrame(() => {
        updateCarouselState(carousel);
        waitingForFrame = false;
      });
    });

    updateCarouselState(carousel);
  });

  window.addEventListener("resize", () => {
    carousels.forEach(updateCarouselState);
  });

  setActiveTab("faciales");
</script>
