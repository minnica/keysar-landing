    description: "Mejora la firmeza y redefine contornos.",
  },
  {
    title: "Experiencia Body VIP Keysar",
    description:
      "Una experiencia integral que combina técnicas avanzadas, atención personalizada y un enfoque sensorial único.",
  },
];

const bodyTreatments = [
  {
    title: "Masaje Relajante",
    description: "Calma profunda que libera estrés y tensión.",
  },
  {
    title: "Masaje Descontracturante",
    description:
      "Alivia tensiones musculares profundas y devuelve movilidad al cuerpo.",
  },
  {
    title: "Drenaje Linfático",
    description: "Ligereza corporal que estimula y desinflama.",
  },
  {
    title: "Masaje Cuerpo Completo",
    description: "Equilibrio total para cuerpo y mente.",
  },
  {
    title: "Reflexología",
    description: "Armonía interna a través de puntos clave.",
  },
  {
    title: "Antiacné Espalda",
    description: "Purificación profunda para una piel uniforme.",
  },
  {
    title: "Piernas Cansadas",
    description: "Frescura inmediata y sensación de ligereza.",
  },
  {
