---
const locations = [
  {
    name: "Sucursal Masaryk",
    address:
      "presidente masaryk 407, Polanco III secc, Miguel Hidalgo, Ciudad de México, Miguel Hidalgo, 11540 CDMX",
    mapUrl: "https://maps.app.goo.gl/F1WFQTv1jn2vUycj6",
  },
  {
    name: "Keysar Cosmétics Mítikah Luxury",
    address:
      "Av Rio Churubusco 601, Xico, Benito Juárez, Ciudad de México. Centro comercial Mítikah. En Mezzanine planta baja acceso por rio Churubusco",
    mapUrl: "https://maps.app.goo.gl/H9raXcMT46Mbsk5R7",
  },
  {
    name: "Sucursal Parque Delta Beauty Córner",
    address:
      "Avenida Cuahutemoc 462, Piedad Narvarte, Benito Juárez, 03000, Ciudad de México, Local K17",
    mapUrl: "https://maps.app.goo.gl/ca9VwBwbok2Dqv9E8",
  },
];
---

<section
  class="bg-gradient-to-b from-[#fbfaf7] to-[#ecd1c8] px-5 py-16 sm:px-6 md:px-10 md:py-20 lg:py-24"
>
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-4xl text-center">
      <h2
        class="font-title text-3xl leading-tight tracking-[-0.03em] text-keysar-text sm:text-4xl md:text-5xl"
      >
        Vive la experiencia Keysar
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-base leading-7 text-keysar-text">
        Encuentra la ubicación más cercana y disfruta de un ambiente íntimo,
        sofisticado y relajante en cada una de nuestras sucursales.
      </p>
    </div>

    <div
      class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-6 sm:mt-12 md:grid-cols-2 md:gap-8"
    >
      {
        locations.map((location) => (
          <article class="group overflow-hidden rounded-[4px] border border-keysar-gold/20 bg-[#e8d6cf] shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
            <div class="flex min-h-[160px] items-center justify-center bg-[#e8d6cf] px-6 py-8 text-center sm:min-h-[180px] sm:px-8 sm:py-10">
              <div>
                <h3 class="font-title text-2xl text-keysar-dark">
                  {location.name}
                </h3>

                <p class="mt-4 text-sm leading-6 text-keysar-text">
                  {location.address}
                </p>

                <a
                  href={location.mapUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-6 inline-flex rounded-full bg-white px-5 py-2 text-sm font-semibold text-keysar-text transition hover:bg-keysar-cream"
                >
                  Ver en Google Maps
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
