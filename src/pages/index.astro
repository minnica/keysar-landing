---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import EssenceAppointment from "../components/EssenceAppointment.astro";
import TreatmentsSection from "../components/TreatmentsSection.astro";
import AppointmentSection from "../components/AppointmentSection.astro";
import VideoReelsSection from "../components/VideoReelsSection.astro";
import LocationsSection from "../components/LocationsSection.astro";
import TestimonialsSection from "../components/TestimonialsSection.astro";
import CTASection from "../components/CTASection.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloatingButton from "../components/WhatsAppFloatingButton.astro";
---

<BaseLayout title="Keysar Cosmetics | Belleza y bienestar">
  <main>
    <Navbar />
    <Hero />
    <EssenceAppointment />
    <TreatmentsSection />
    <VideoReelsSection />
    <AppointmentSection />
    <LocationsSection />
    <TestimonialsSection />
    <CTASection />
  </main>

  <Footer />
  <WhatsAppFloatingButton />
</BaseLayout>
